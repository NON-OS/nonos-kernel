{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nonos/abi/marketplace_index.schema.json",
  "title": "NONOS marketplace index",
  "description": "Logical schema for the marketplace index snapshot the operator publishes (e.g. 0xNOX `/api/v1/marketplace/index`). The on-the-wire form is a length-prefixed binary blob; this JSON describes the same fields for indexing, audit, and reproducible-build pipelines. capsule_market parses the binary form and never trusts an entry whose `index_signature` does not verify against `operator_pubkey`. Per-package detail (manifest, artifacts, signatures) lives inside the package and is governed by capsule_manifest.schema.json and capsule_package.schema.json; this schema covers only the marketplace summary that bridges discovery to install.",
  "type": "object",
  "required": [
    "schema_version",
    "operator_id",
    "operator_pubkey",
    "published_at_ms",
    "serial",
    "entries",
    "index_signature"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "operator_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "operator_pubkey": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "Hex-encoded Ed25519 public key, 32 bytes. The capsule trusts an index only after `index_signature` checks against this key."
    },
    "published_at_ms": { "type": "integer", "minimum": 0 },
    "serial": {
      "type": "integer",
      "minimum": 0,
      "description": "Strictly-increasing snapshot number. capsule_market refuses an index whose `serial` is below the last accepted value, so a rollback by a compromised mirror cannot revive a revoked listing."
    },
    "entries": {
      "type": "array",
      "maxItems": 1024,
      "items": { "$ref": "#/$defs/Entry" }
    },
    "index_signature": {
      "type": "string",
      "pattern": "^[0-9a-f]{128}$",
      "description": "Hex-encoded Ed25519 signature, 64 bytes, over the canonical encoding of every preceding field in declaration order."
    }
  },
  "$defs": {
    "Entry": {
      "type": "object",
      "required": [
        "listing_id",
        "capsule_id",
        "name",
        "publisher_name",
        "publisher_pubkey",
        "description",
        "price",
        "token",
        "releases"
      ],
      "additionalProperties": false,
      "properties": {
        "listing_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "capsule_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "BLAKE3-derived capsule_id; matches the manifest's capsule_id."
        },
        "name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "publisher_name": { "type": "string", "maxLength": 128 },
        "publisher_pubkey": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "Same key shape as capsule_manifest.schema.json#publisher.pubkey."
        },
        "description": { "type": "string", "maxLength": 4096 },
        "price": { "$ref": "capsule_manifest.schema.json#/properties/payment_policy" },
        "token": { "$ref": "#/$defs/Token" },
        "releases": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": { "$ref": "#/$defs/Release" }
        }
      }
    },
    "Release": {
      "type": "object",
      "required": [
        "release_id",
        "manifest_hash",
        "package_hash",
        "package_url",
        "publisher_signature",
        "supported_arches",
        "kernel_abi_min",
        "required_capabilities",
        "validation"
      ],
      "additionalProperties": false,
      "properties": {
        "release_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "manifest_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "package_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "package_url": {
          "type": "string",
          "maxLength": 1024,
          "description": "HTTPS URL the installer pulls the package from. Empty when the entry is index-only."
        },
        "publisher_signature": {
          "type": "string",
          "pattern": "^([0-9a-f]{128})?$",
          "description": "Hex-encoded Ed25519 signature over the canonical release bytes; 64 bytes when present, empty for unsigned dev fixtures."
        },
        "supported_arches": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["x86_64-nonos", "aarch64-nonos", "riscv64-nonos"]
          }
        },
        "kernel_abi_min": { "type": "integer", "minimum": 1, "maximum": 4294967295 },
        "required_capabilities": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "capsule_manifest.schema.json#/$defs/CapName" }
        },
        "validation": { "$ref": "#/$defs/Validation" }
      }
    },
    "Validation": {
      "type": "object",
      "required": ["status", "validator_id", "validated_at_ms"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["unknown", "pending", "validated", "rejected"]
        },
        "note": { "type": "string", "maxLength": 4096 },
        "validator_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "validated_at_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "Token": {
      "type": "object",
      "required": ["symbol", "decimals", "chain_id"],
      "additionalProperties": false,
      "properties": {
        "symbol": { "type": "string", "minLength": 1, "maxLength": 16 },
        "decimals": { "type": "integer", "minimum": 0, "maximum": 32 },
        "chain_id": { "type": "integer", "minimum": 0, "maximum": 18446744073709551615 },
        "contract_address": {
          "type": "string",
          "pattern": "^(0x[0-9a-fA-F]{40})?$",
          "description": "ERC-20 contract address; empty for the chain's native token."
        }
      }
    }
  }
}
