# Build outputs
target/
*.iso
*.img
*.bin
!firmware/*.fd
!nonos-bootloader/firmware/**/*.bin

# IDE and editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Python
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Node
node_modules/

# Secrets and keys { NEVER COMMITED }
/keys/
.keys/*
!.keys/.gitignore
!.keys/*.pub
!src/**/keys/
*.key
*.pem
*_key.bin
*_key.json
signing_key*.bin
signing_key*.json
dev_signing_key.bin
*.secret

# Signed capsule artifacts ship with the kernel build so CI can
# reverify them against the committed publisher pubkey + NØNOS
# root pubkey. Seeds remain ignored above.
!userland/capsule_*/*.publisher_cert.bin
!userland/capsule_*/*.manifest.bin

# ZK artifacts (generated, large)
zk-artifacts/generated/
zk-artifacts/*.bin
zk-artifacts/*.json
!zk-artifacts/README.md
generated_keys/

# Logs and temp files
*.log
*.tmp
*.temp

# Build cache
.cargo/
.rustup/

# Test outputs
test-results/
coverage/

# Local config overrides
.env
.env.local
*.local.toml

# AI assistant instruction files (local overrides, not for version control)
.claude/
CLAUDE.md
.cursorrules
.cursorignore
.aider*
.continue/

