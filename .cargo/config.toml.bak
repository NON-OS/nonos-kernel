[build]
target = "x86_64-nonos.json"

[unstable]
build-std = ["core", "alloc"]
build-std-features = ["compiler-builtins-mem"]

[target.x86_64-nonos]
runner = "qemu-system-x86_64 -machine q35 -cpu qemu64 -m 1024M -drive if=pflash,format=raw,readonly=on,file=/usr/local/Cellar/qemu/10.1.3/share/qemu/edk2-x86_64-code.fd -drive format=raw,file=fat:rw:target/esp -serial stdio -display cocoa -no-reboot"
rustflags = [
  "-C", "force-frame-pointers=yes",
]
